# Copy to .env and adjust. Never commit .env.

# Flask
FLASK_APP=app.py
FLASK_DEBUG=0
SECRET_KEY=change-me-to-a-long-random-string

# SQLite (default: sign2speak.db in project root)
# DB_PATH=C:\path\to\custom\sign2speak.db

# Hugging Face (Windows: avoid symlink errors without admin rights)
HF_HUB_DISABLE_SYMLINKS=1

# Optional: TensorFlow / PyTorch noise reduction
# TF_ENABLE_ONEDNN_OPTS=0
# TF_USE_LEGACY_KERAS=1
# TORCH_CUDNN_NOSUPPORT=1
